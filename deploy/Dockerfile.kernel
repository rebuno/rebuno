FROM golang:1.26-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /rebuno ./cmd/rebuno

FROM alpine:3.19
RUN apk --no-cache add ca-certificates && \
    addgroup -S rebuno && adduser -S rebuno -G rebuno
COPY --from=builder /rebuno /usr/local/bin/rebuno
USER rebuno
EXPOSE 8080
ENTRYPOINT ["rebuno", "server"]
